# 🤖 多 Agent 系统环境变量配置
# 复制此文件为 .env 并填入实际的 API Keys

# ============================================
# API Keys (必需)
# ============================================

# Anthropic API Key (用于 Claude 模型)
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API Key (用于 GPT 模型)
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=sk-your-key-here

# Google API Key (用于 Gemini 模型)
# 获取地址: https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key-here

# ============================================
# 模型选择配置 (可选)
# 如果不设置，将使用 models.yaml 中的默认配置
# ============================================

# Master Agent 模型
# MASTER_AGENT_MODEL=claude-3-5-sonnet-20241022
# MASTER_AGENT_TEMPERATURE=0.3
# MASTER_AGENT_MAX_TOKENS=4096

# Product Agent 模型
# PRODUCT_AGENT_MODEL=gpt-4o
# PRODUCT_AGENT_TEMPERATURE=0.7
# PRODUCT_AGENT_MAX_TOKENS=4096

# Tech Agent 模型
# TECH_AGENT_MODEL=claude-3-5-sonnet-20241022
# TECH_AGENT_TEMPERATURE=0.2
# TECH_AGENT_MAX_TOKENS=8192

# Testing Agent 模型
# TESTING_AGENT_MODEL=claude-3-5-sonnet-20241022
# TESTING_AGENT_TEMPERATURE=0.2
# TESTING_AGENT_MAX_TOKENS=4096

# ============================================
# 成本控制配置 (可选)
# ============================================

# 每日预算限制 (美元)
DAILY_BUDGET=10.0

# 是否启用成本追踪
ENABLE_COST_TRACKING=true

# 成本警告阈值 (0.0 - 1.0)
COST_WARNING_THRESHOLD=0.8

# ============================================
# 性能配置 (可选)
# ============================================

# 是否启用缓存
ENABLE_CACHE=true

# 缓存 TTL (秒)
CACHE_TTL=3600

# 最大并行 Agent 数
MAX_PARALLEL_AGENTS=2

# 请求超时时间 (秒)
REQUEST_TIMEOUT=300

# ============================================
# 日志配置 (可选)
# ============================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 是否启用详细日志
ENABLE_VERBOSE_LOGGING=true

# ============================================
# 预设配置 (可选)
# ============================================

# 激活的预设: development, production, high_quality, rapid_prototype
ACTIVE_PRESET=development
